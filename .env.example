# ============================================================
# 🤖 Agent Framework Configuration (.env)
# Copy this file to `.env` and adjust values for your environment.
# Pydantic will automatically map these uppercase vars to the 
# snake_case fields in config.py.
# ============================================================

# LLM Configuration
MODEL_NAME=gpt-4o
API_KEY=your-api-key-here

# Workspace & Filesystem (Must be an absolute path)
WORKSPACE_ROOT=/path/to/agent/workspace

# HTTP Timeouts (seconds)
HTTP_TIMEOUT_CONNECT=5.0
HTTP_TIMEOUT_READ=30.0

# Index & Search Configuration
MAX_INDEX_SIZE=5000
CHUNK_OVERLAY_BYTES=512

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO